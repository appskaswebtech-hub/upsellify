// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}
model Shop {
  id                    String    @id @default(cuid())
  shop                  String    @unique
  installedAt           DateTime  @default(now())
  uninstalledAt         DateTime?
  plan                  String    @default("free")
  currency              String    @default("USD")
  locale                String    @default("en")
  timezone              String    @default("America/New_York")

  embedEnabled          Boolean   @default(false)
  firstCampaignCreated  Boolean   @default(false)
  storeVerified         Boolean   @default(false)

  // Widget defaults
  widgetTitle           String    @default("Frequently bought together")
  widgetSubtitle        String?
  widgetCtaLabel        String    @default("Add bundle to cart")
  widgetAccentColor     String    @default("#000000")
  widgetTextColor       String    @default("#202020")
  widgetBorderRadius    Int       @default(8)
  widgetFontFamily      String    @default("inherit")

  // Shopify Function discount (one per shop, reused across campaigns)
  shopifyDiscountId     String?

  campaigns             Campaign[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Campaign {
  id            String   @id @default(cuid())
  shop          String
  shopRef       Shop     @relation(fields: [shop], references: [shop], onDelete: Cascade)

  name          String
  type          String   @default("FBT_LIST")    // FBT_LIST | FBT_AMAZON | FBT_CLASSIC
  status        String   @default("DRAFT")       // DRAFT | ACTIVE | PAUSED | SCHEDULED | EXPIRED
  placement     String   @default("PRODUCT_PAGE")
  priority      Int      @default(0)

  startDate     DateTime?
  endDate       DateTime?
  timezone      String    @default("America/New_York")

  triggerType   String    @default("SPECIFIC_PRODUCTS") // ALL_PRODUCTS | SPECIFIC_PRODUCTS | SPECIFIC_COLLECTIONS

  title         String?
  subtitle      String?

  showQuantityPicker    Boolean @default(false)
  allowDeselectTrigger  Boolean @default(false)
  doNotPreselect        Boolean @default(false)
  randomizeOffers       Boolean @default(false)
  limitOffersShown      Int?
  autoMatchVariants     Boolean @default(false)

  triggers      CampaignTrigger[]
  offers        CampaignOffer[]
  discount      Discount?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([shop, status])
  @@index([shop, placement, status])
}

model CampaignTrigger {
  id             String   @id @default(cuid())
  campaignId     String
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  resourceType   String   // "product" | "collection"
  resourceId     String   // Shopify GID
  resourceTitle  String
  resourceHandle String?
  imageUrl       String?
  position       Int      @default(0)

  @@index([campaignId])
  @@index([resourceId])
}

model CampaignOffer {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId     String   // Shopify GID
  productTitle  String
  productHandle String?
  imageUrl      String?
  variantId     String?
  position      Int      @default(0)

  @@index([campaignId])
}

model Discount {
  id                String   @id @default(cuid())
  shop              String
  campaignId        String   @unique
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  type              String   @default("NONE") // NONE | PERCENTAGE | FIXED | TIERED
  value             Float?

  tiers             DiscountTier[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shop])
}

model DiscountTier {
  id         String   @id @default(cuid())
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  minItems   Int
  valueType  String   // PERCENTAGE | FIXED
  value      Float
  label      String?
  position   Int      @default(0)

  @@index([discountId])
}

model CollectionProductCache {
  id           String   @id @default(cuid())
  shop         String
  collectionId String
  productIds   Json
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt

  @@unique([shop, collectionId])
  @@index([expiresAt])
}
model AnalyticsEvent {
  id          String    @id @default(cuid())
  shop        String
  campaignId  String?
  eventType   String    // IMPRESSION | CLICK | ADD_TO_CART | PURCHASE
  sessionId   String?
  productId   String?
  orderId     String?
  revenue     Float?
  currency    String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([shop, campaignId, eventType])
  @@index([shop, createdAt])
  @@index([shop, eventType, createdAt])
}
